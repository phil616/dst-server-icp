# DST Serverd 配置(复制为 config.yaml)。替代环境变量,告诉后端 db/目录在哪。
# 查找顺序:$DSTD_CONFIG → ./config.yaml → 仓库根/config.yaml → /etc/dst-serverd/config.yaml

# DST 安装根:SteamCMD / 服务端本体 / MOD / 存档都在这下面(见 DESIGN.md 2.2)
base: /opt/dst
# Cluster 配置目录名:<base>/<conf_dir>/<cluster>/
conf_dir: clusters

# 后端监听
host: 127.0.0.1
port: 8000
# 面板自己的 SQLite(相对路径相对本 config.yaml 所在目录)
db: data/dstd.sqlite3
secret_key: change-me

# 优雅关停超时(秒)
shutdown_grace: 30
sigterm_grace: 10
